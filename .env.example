# ── PostgreSQL (with pgvector) ──────────────────────────────────
DATABASE_URL=postgresql+asyncpg://arxgorithm:arxgorithm@postgres:5432/arxgorithm

# ── DeepInfra Embedding API ─────────────────────────────────────
DEEPINFRA_API_KEY=your-deepinfra-api-key-here
# EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
# EMBEDDING_DIMENSION=1024
# EMBEDDING_API_URL=https://api.deepinfra.com/v1/openai/embeddings
# EMBEDDING_BATCH_SIZE=64

# ── JWT ──────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production

# ── LLM (agentic recommendation, OpenAI-compatible) ─────────────
# LLM_API_KEY=
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# ── Crawler Schedule ──────────────────────────────────────────
# CRAWL_SCHEDULE_HOURS=24
# CRAWL_QUERY=cat:cs.AI
# CRAWL_MAX_RESULTS=200

# ── CORS ────────────────────────────────────────────────────────
# CORS_ORIGINS=["http://localhost:3000"]

# ── Frontend ────────────────────────────────────────────────────
